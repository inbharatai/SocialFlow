# SocialFlow Configuration

# ── AI Text Provider ──────────────────────────────────────────────────────────
# Choose which AI generates your content: ollama | openai | anthropic | gemini
# Default: ollama (free, local, no API key needed)
AI_PROVIDER=ollama

# Optional: Cloud AI API keys (only needed if AI_PROVIDER is not ollama)
# OPENAI_API_KEY=sk-your-openai-api-key-here
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
# GEMINI_API_KEY=AIza-your-gemini-api-key-here

# ── HeyGen Video Generation ──────────────────────────────────────────────────
# Browser-based login (NOT API). Credentials encrypted locally.
# Set these OR add via SocialFlow dashboard: http://localhost:8000
HEYGEN_EMAIL=your-heygen-email@example.com
HEYGEN_PASSWORD=your-heygen-password

# ── Browser Mode ──────────────────────────────────────────────────────────────
# false = visible browser (recommended for first login, more reliable)
# true = headless/invisible browser (use after sessions are established)
HEADLESS=false

# ── Ollama (Local AI) ────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
