# SocialFlow Configuration

# OpenAI API Key (REQUIRED for content generation & images)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Kling AI API Key (REQUIRED for video generation)
# Get your key at: https://klingai.com/global/dev
KLING_API_KEY=your-kling-api-key-here

# Browser Mode
# false = visible browser (recommended, more reliable)
# true = headless/invisible browser
HEADLESS=false
