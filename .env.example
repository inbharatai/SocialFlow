# SocialFlow Configuration

# ── AI Text Provider ──────────────────────────────────────────────────────────
# Choose which AI generates your content: openai | anthropic | gemini
AI_PROVIDER=openai

# OpenAI API Key (GPT-4o) — paid, most capable
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key (Claude Haiku) — free trial credits on sign-up
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Google Gemini API Key (Gemini 2.0 Flash) — generous free tier
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza-your-gemini-api-key-here

# ── Video Generation ──────────────────────────────────────────────────────────
# Kling AI API Key (REQUIRED for video & avatar generation)
# Get your key at: https://klingai.com/global/dev
KLING_API_KEY=your-kling-api-key-here

# ── Browser Mode ──────────────────────────────────────────────────────────────
# false = visible browser (recommended, more reliable)
# true = headless/invisible browser
HEADLESS=false
